{
  "name": "jirallm",
  "version": "0.1.1",
  "description": "Export Jira issues as LLM-ready context bundles — markdown, attachments, video frames",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "jirallm": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src scripts",
    "test": "vitest run --bail=5",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build && pnpm test",
    "release": "tsx scripts/release.ts"
  },
  "keywords": [
    "jira",
    "llm",
    "ai",
    "claude",
    "context",
    "export",
    "markdown",
    "adf",
    "video-frames",
    "ffmpeg"
  ],
  "author": "Dominik Rycharski (https://github.com/Doryski)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Doryski/jirallm.git"
  },
  "bugs": {
    "url": "https://github.com/Doryski/jirallm/issues"
  },
  "homepage": "https://github.com/Doryski/jirallm#readme",
  "engines": {
    "node": ">=20"
  },
  "os": [
    "darwin",
    "linux",
    "win32",
    "freebsd"
  ],
  "cpu": [
    "x64",
    "arm64",
    "arm",
    "ia32",
    "riscv64"
  ],
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@iarna/toml": "^2.2.5",
    "@napi-rs/keyring": "^1.3.0",
    "commander": "^14.0.3",
    "pixelmatch": "^6.0.0",
    "sharp": "^0.33.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/iarna__toml": "^2.0.5",
    "@types/node": "^22.0.0",
    "@types/pixelmatch": "^5.2.6",
    "eslint": "^10.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.5"
  }
}
